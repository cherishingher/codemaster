# Core services
DATABASE_URL="postgresql://postgres:CHANGE_ME@127.0.0.1:5432/oj?schema=public"
REDIS_URL="redis://:CHANGE_ME@127.0.0.1:6379"

# Auth — REQUIRED, must be changed before running
AUTH_CODE_SECRET=""
# WARNING: never enable in production
DEBUG_AUTH_CODES="false"
BOOTSTRAP_ADMIN_EMAIL=""

# Aliyun verification code (SMS / DirectMail)
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_REGION_ID="cn-hangzhou"
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""
ALIYUN_DM_ACCOUNT_NAME=""
ALIYUN_DM_FROM_ALIAS=""
ALIYUN_DM_SUBJECT="验证码"
ALIYUN_DM_TAG_NAME=""

# Judge callback / local runner — REQUIRED, must be changed
JUDGE_CALLBACK_SECRET=""
API_BASE_URL="http://127.0.0.1:3001"
JUDGE_ID="judge-local"
ENABLE_LOCAL_RUNNER="false"
CPP_COMPILER="g++"

# HUSTOJ bridge
HUSTOJ_MYSQL_HOST="127.0.0.1"
HUSTOJ_MYSQL_PORT="3306"
HUSTOJ_MYSQL_USER=""
HUSTOJ_MYSQL_PASSWORD=""
HUSTOJ_MYSQL_DB="jol"
HUSTOJ_DATA_DIR="/home/judge/data"

# Docker Compose credentials
POSTGRES_PASSWORD=""
REDIS_PASSWORD=""

# Optional
LOCAL_STORAGE_DIR="./apps/web/storage"
NEXT_PUBLIC_GRAPHICAL_URL="/graphical/index.html"
MAX_TESTCASE_ZIP_BYTES="209715200"
MAX_TESTCASE_FILE_BYTES="10485760"
MAX_TESTCASE_COUNT="500"
