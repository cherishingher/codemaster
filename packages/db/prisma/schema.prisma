  logs                  TestdataGenerationLog[]

  @@unique([taskId, ordinal])
  @@index([taskId, status, ordinal])
  @@index([taskId, groupKey, ordinal])
  @@index([taskId, executionStatus])
  @@index([inputAssetId])
  @@index([expectedOutputAssetId])
}

model TestdataGenerationLog {
