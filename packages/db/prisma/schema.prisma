datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum StandardSolutionStatus {
  ACTIVE
  ARCHIVED
  DISABLED
  INVALID
}

enum TestdataGenerationTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum TestdataGenerationTaskStage {
  VALIDATE_CONFIG
  PREPARE_WORKDIR
  COMPILE_SOLUTION
  PLAN_CASES
  GENERATE_INPUTS
  VALIDATE_INPUTS
  RUN_SOLUTION
  PERSIST_CASES
  FINALIZE
}

enum TestdataPublishMode {
  APPEND
  REPLACE_GENERATED
  REPLACE_ALL
}

enum TestdataCaseStatus {
  PENDING
  INPUT_READY
  RUNNING
  OUTPUT_READY
  PERSISTED
  FAILED
  SKIPPED
}

enum ProgramExecutionStatus {
  NOT_STARTED
  SUCCESS
  COMPILE_ERROR
  RUNTIME_ERROR
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  OUTPUT_LIMIT_EXCEEDED
  SYSTEM_ERROR
}

enum GenerationLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum FileAssetKind {
  SOURCE_CODE
  TESTCASE_INPUT
  TESTCASE_EXPECTED_OUTPUT
  COMPILE_STDOUT
  COMPILE_STDERR
  RUNTIME_STDERR
  TASK_MANIFEST
  TASK_PACKAGE
}

enum FileStorageProvider {
  LOCAL_FILE
  S3
  OSS
}

enum FileAssetStatus {
  ACTIVE
  ORPHANED
  DELETED
}

enum TestcaseSourceType {
  MANUAL
  ZIP_IMPORT
  AUTO_GENERATED
}

model User {
  id                                  String                              @id @default(cuid())
  email                               String?                             @unique
  phone                               String?                             @unique
  emailVerifiedAt                     DateTime?
  phoneVerifiedAt                     DateTime?
  password                            String
  name                                String?
  status                              String                              @default("active")
  pointsBalance                       Int                                 @default(0)
  createdAt                           DateTime                            @default(now())
  updatedAt                           DateTime                            @updatedAt
  roles                               UserRole[]
  sessions                            Session[]
  submissions                         Submission[]
  enrollments                         Enrollment[]
  orders                              Order[]
  posts                               Post[]
  comments                            Comment[]
  contestParticipants                 ContestParticipant[]
  contestRegistrations                ContestRegistration[]
  contestReports                      ContestReport[]
  guardianRelationsAsGuardian         GuardianRelation[]                  @relation("GuardianUser")
  guardianRelationsAsStudent          GuardianRelation[]                  @relation("StudentUser")
  parentReportSnapshotsAsGuardian     ParentReportSnapshot[]              @relation("ParentReportGuardian")
  parentReportSnapshotsAsStudent      ParentReportSnapshot[]              @relation("ParentReportStudent")
  teacherProfile                      TeacherProfile?
  organizationMemberships             OrganizationMember[]
  teachingGroupsOwned                 TeachingGroup[]                     @relation("TeachingGroupOwner")
  teachingGroupMemberships            TeachingGroupMember[]
  teachingGroupAssignments            TeachingGroupProblemSetAssignment[] @relation("TeachingGroupAssignmentOperator")
  teachingGroupAssignmentGrades       TeachingGroupAssignmentGrade[]
  gradedTeachingGroupAssignmentGrades TeachingGroupAssignmentGrade[]      @relation("TeachingGroupAssignmentGradeGrader")
  organizationApiKeys                 OrganizationApiKey[]
  contentAssets                       ContentAsset[]                      @relation("ContentAssetUploader")
  contentWorkflowLogs                 ContentWorkflowLog[]                @relation("ContentWorkflowOperator")
  moderationLogs                      ModerationLog[]
  adminProblemBulkOperationLogs       AdminProblemBulkOperationLog[]
  solutions                           Solution[]
  problemSets                         ProblemSet[]
  problemProgress                     UserProblemProgress[]
  entitlements                        Entitlement[]
  membershipSubscriptions             MembershipSubscription[]
  refundRequests                      RefundRequest[]
  campEnrollments                     CampEnrollment[]
  campCheckins                        CampCheckin[]
  campRankSnapshots                   CampRankSnapshot[]
  studyGroupsOwned                    StudyGroup[]                        @relation("StudyGroupOwner")
  studyGroupMemberships               StudyGroupMember[]
  pointTransactions                   PointTransaction[]
  pointRedemptions                    PointRedemption[]
  standardSolutionsUploaded           StandardSolution[]                  @relation("StandardSolutionUploader")
  testdataGenerationTasksRequested    TestdataGenerationTask[]            @relation("TestdataGenerationRequester")
  fileAssetsCreated                   FileAsset[]                         @relation("FileAssetCreator")
}

model VerificationCode {
  id        String    @id @default(cuid())
  target    String
  type      String
  purpose   String    @default("register")
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int       @default(0)
  ip        String?
  createdAt DateTime  @default(now())

  @@index([target, type, purpose, createdAt])
  @@index([expiresAt])
}

model Role {
  id    String     @id @default(cuid())
  name  String     @unique
  users UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Problem {
  id                      String                   @id @default(cuid())
  slug                    String                   @unique
  title                   String
  difficulty              Int
  status                  Int                      @default(0)
  visible                 Boolean                  @default(true)
  defunct                 String                   @default("N") @db.Char(1)
  visibility              String                   @default("public")
  source                  String?
  publishedAt             DateTime?
  totalSubmissions        Int                      @default(0)
  acceptedSubmissions     Int                      @default(0)
  passRate                Float                    @default(0)
  currentVersionId        String?                  @unique
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  aliases                 ProblemAlias[]
  tags                    ProblemTag[]
  versions                ProblemVersion[]         @relation("ProblemVersions")
  currentVersion          ProblemVersion?          @relation("ProblemCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  submissions             Submission[]
  contestProblems         ContestProblem[]
  solutions               Solution[]
  problemSetItems         ProblemSetItem[]
  stats                   ProblemStat?
  progress                UserProblemProgress[]
  hustojMap               HustojProblemMap?
  campTasks               CampTask[]
  testdataGenerationTasks TestdataGenerationTask[]

  @@index([difficulty])
  @@index([status, visible, defunct, publishedAt])
  @@index([createdAt])
}

model ProblemAlias {
  id              String   @id @default(cuid())
  problemId       String
  value           String
  normalizedValue String   @unique
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  problem         Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId, sortOrder])
}

model ProblemVersion {
  id                       String                   @id @default(cuid())
  problemId                String
  version                  Int
  statement                String
  statementMd              String?
  constraints              String?
  hints                    String?
  inputFormat              String?
  outputFormat             String?
  samples                  Json?
  scratchRules             Json?
  testdataGenerationConfig Json?
  notes                    String?
  timeLimitMs              Int
  memoryLimitMb            Int
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  problem                  Problem                  @relation("ProblemVersions", fields: [problemId], references: [id])
  currentFor               Problem[]                @relation("ProblemCurrentVersion")
  testcases                Testcase[]
  judgeConfigs             ProblemJudgeConfig[]
  submissions              Submission[]
  solutions                Solution[]
  standardSolutions        StandardSolution[]
  testdataGenerationTasks  TestdataGenerationTask[]

  @@unique([problemId, version])
  @@index([problemId])
  @@index([problemId, createdAt])
}

model Testcase {
  id                String                  @id @default(cuid())
  versionId         String
  title             String?
  caseType          Int                     @default(1)
  visible           Boolean                 @default(false)
  inputUri          String
  outputUri         String
  score             Int
  timeLimitMs       Int?
  memoryLimitKb     Int?
  subtaskId         Int?
  isPretest         Boolean                 @default(false)
  groupId           String?
  isSample          Boolean                 @default(false)
  sourceType        TestcaseSourceType      @default(MANUAL)
  generationTaskId  String?
  generationOrdinal Int?
  orderIndex        Int?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  version           ProblemVersion          @relation(fields: [versionId], references: [id])
  cases             SubmissionCase[]
  generationTask    TestdataGenerationTask? @relation("GeneratedTestcases", fields: [generationTaskId], references: [id])

  @@index([versionId])
  @@index([versionId, caseType, orderIndex])
  @@index([versionId, groupId])
  @@index([generationTaskId, generationOrdinal])
}

model Tag {
  id       String       @id @default(cuid())
  name     String       @unique
  problems ProblemTag[]
}

model ProblemTag {
  problemId String
  tagId     String
  problem   Problem @relation(fields: [problemId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([problemId, tagId])
  @@index([tagId])
}

model Submission {
  id               String           @id @default(cuid())
  userId           String
  problemId        String
  problemVersionId String
  lang             String
  languageId       Int?
  codeUri          String?
  code             String?          @db.Text
  status           String           @default("QUEUED")
  judgeResult      Int              @default(0)
  score            Int              @default(0)
  judgeBackend     String           @default("hustoj")
  hustojSolutionId Int?
  timeUsedMs       Int?
  memoryUsedKb     Int?
  visible          Boolean          @default(true)
  defunct          String           @default("N") @db.Char(1)
  createdAt        DateTime         @default(now())
  finishedAt       DateTime?
  updatedAt        DateTime         @updatedAt
  user             User             @relation(fields: [userId], references: [id])
  problem          Problem          @relation(fields: [problemId], references: [id])
  problemVersion   ProblemVersion   @relation(fields: [problemVersionId], references: [id])
  cases            SubmissionCase[]
  sourceCode       SourceCode?
  compileInfo      CompileInfo?
  runtimeInfo      RuntimeInfo?

  @@index([userId, createdAt])
  @@index([problemId, createdAt])
  @@index([status])
  @@index([judgeResult, createdAt])
  @@index([problemVersionId, createdAt])
}

model HustojProblemMap {
  id              String   @id @default(cuid())
  problemId       String   @unique
  hustojProblemId Int      @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  problem         Problem  @relation(fields: [problemId], references: [id])

  @@index([hustojProblemId])
}

model SubmissionCase {
  id              String     @id @default(cuid())
  submissionId    String
  testcaseId      String?
  ordinal         Int?
  status          String
  judgeResult     Int        @default(0)
  timeMs          Int
  memoryMb        Int
  score           Int
  inputPreview    String?    @db.Text
  outputPreview   String?    @db.Text
  expectedPreview String?    @db.Text
  checkerMessage  String?    @db.Text
  createdAt       DateTime   @default(now())
  submission      Submission @relation(fields: [submissionId], references: [id])
  testcase        Testcase?  @relation(fields: [testcaseId], references: [id])

  @@unique([submissionId, testcaseId])
  @@index([submissionId])
  @@index([submissionId, ordinal])
}

model ProblemJudgeConfig {
  id              String         @id @default(cuid())
  versionId       String
  language        String
  languageId      Int
  judgeMode       String         @default("standard")
  timeLimitMs     Int?
  memoryLimitMb   Int?
  templateCode    String?        @db.Text
  templateCodeUri String?
  entrypoint      String?
  entrySignature  String?
  compileCommand  String?
  runCommand      String?
  isEnabled       Boolean        @default(true)
  isDefault       Boolean        @default(false)
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  version         ProblemVersion @relation(fields: [versionId], references: [id])

  @@unique([versionId, language])
  @@index([versionId, isEnabled, sortOrder])
  @@index([languageId])
}

model SourceCode {
  submissionId String     @id
  source       String?    @db.Text
  objectKey    String?
  storageType  String     @default("inline")
  sourceSize   Int?
  sourceHash   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id])
}

model CompileInfo {
  submissionId String     @id
  compiler     String?
  command      String?
  exitCode     Int?
  message      String?    @db.Text
  objectKey    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id])
}

model RuntimeInfo {
  submissionId   String     @id
  exitCode       Int?
  signal         String?
  stdoutPreview  String?    @db.Text
  stderrPreview  String?    @db.Text
  checkerMessage String?    @db.Text
  objectKey      String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  submission     Submission @relation(fields: [submissionId], references: [id])
}

model Contest {
  id                  String                @id @default(cuid())
  slug                String                @unique
  name                String
  summary             String?
  description         String?
  coverImage          String?
  status              String                @default("draft")
  visibility          String                @default("public")
  accessLevel         String?
  registrationLimit   Int?
  registrationStartAt DateTime?
  registrationEndAt   DateTime?
  startAt             DateTime
  endAt               DateTime
  rule                String                @default("ACM")
  sortOrder           Int                   @default(0)
  publishedAt         DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  problems            ContestProblem[]
  participants        ContestParticipant[]
  registrations       ContestRegistration[]
  reports             ContestReport[]
  unlockRules         ContestUnlockRule[]

  @@index([status, sortOrder])
  @@index([visibility, status, sortOrder])
  @@index([startAt, endAt])
}

model ContestProblem {
  contestId String
  problemId String
  order     Int
  contest   Contest @relation(fields: [contestId], references: [id])
  problem   Problem @relation(fields: [problemId], references: [id])

  @@id([contestId, problemId])
  @@index([contestId, order])
}

model ContestParticipant {
  contestId  String
  userId     String
  orderId    String?   @unique
  status     String    @default("PENDING_PAYMENT")
  sourceType String    @default("PURCHASE")
  sourceId   String?
  joinedAt   DateTime  @default(now())
  paidAt     DateTime?
  updatedAt  DateTime  @updatedAt
  contest    Contest   @relation(fields: [contestId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
  order      Order?    @relation(fields: [orderId], references: [id])

  @@id([contestId, userId])
  @@index([contestId])
  @@index([contestId, status, joinedAt])
  @@index([userId, status, joinedAt])
}

model ContestRegistration {
  id         String    @id @default(cuid())
  contestId  String
  userId     String
  orderId    String?   @unique
  status     String    @default("PENDING_PAYMENT")
  sourceType String    @default("PURCHASE")
  sourceId   String?
  groupKey   String    @default("public")
  groupLabel String    @default("公开组")
  joinedAt   DateTime  @default(now())
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  contest    Contest   @relation(fields: [contestId], references: [id])
  user       User      @relation(fields: [userId], references: [id])
  order      Order?    @relation(fields: [orderId], references: [id])

  @@unique([contestId, userId])
  @@index([contestId, status, joinedAt])
  @@index([contestId, groupKey, status, joinedAt])
  @@index([userId, status, joinedAt])
}

model ContestReport {
  id              String   @id @default(cuid())
  contestId       String
  userId          String
  reportType      String   @default("personal")
  groupKey        String?
  solvedCount     Int      @default(0)
  submissionCount Int      @default(0)
  penaltyMinutes  Int      @default(0)
  score           Int      @default(0)
  rank            Int?
  groupRank       Int?
  summary         String?
  payload         Json?
  generatedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  contest         Contest  @relation(fields: [contestId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@unique([contestId, userId, reportType])
  @@index([contestId, reportType, generatedAt])
  @@index([contestId, groupKey, reportType, generatedAt])
  @@index([userId, reportType, generatedAt])
}

model ContestUnlockRule {
  id             String    @id @default(cuid())
  contestId      String
  resourceType   String
  requiredSource String    @default("PURCHASE")
  startsAt       DateTime?
  endsAt         DateTime?
  isEnabled      Boolean   @default(true)
  summary        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  contest        Contest   @relation(fields: [contestId], references: [id])

  @@unique([contestId, resourceType])
  @@index([contestId, isEnabled])
}

model GuardianRelation {
  id             String   @id @default(cuid())
  guardianUserId String
  studentUserId  String
  relation       String   @default("parent")
  status         String   @default("active")
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  guardian       User     @relation("GuardianUser", fields: [guardianUserId], references: [id])
  student        User     @relation("StudentUser", fields: [studentUserId], references: [id])

  @@unique([guardianUserId, studentUserId])
  @@index([guardianUserId, status, createdAt])
  @@index([studentUserId, status, createdAt])
}

model ParentReportSnapshot {
  id             String   @id @default(cuid())
  guardianUserId String
  studentUserId  String
  periodType     String   @default("weekly")
  periodStartAt  DateTime
  periodEndAt    DateTime
  summary        String?
  payload        Json?
  generatedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  guardian       User     @relation("ParentReportGuardian", fields: [guardianUserId], references: [id])
  student        User     @relation("ParentReportStudent", fields: [studentUserId], references: [id])

  @@unique([guardianUserId, studentUserId, periodType, periodStartAt, periodEndAt])
  @@index([guardianUserId, periodType, generatedAt])
  @@index([studentUserId, periodType, generatedAt])
}

model Organization {
  id              String               @id @default(cuid())
  slug            String               @unique
  name            String
  shortName       String?
  externalCode    String?              @unique
  type            String               @default("institution")
  status          String               @default("draft")
  description     String?
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  settings        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  members         OrganizationMember[]
  teacherProfiles TeacherProfile[]
  teachingGroups  TeachingGroup[]
  apiKeys         OrganizationApiKey[]

  @@index([type, status, createdAt])
  @@index([status, createdAt])
}

model OrganizationMember {
  organizationId String
  userId         String
  role           String       @default("member")
  status         String       @default("active")
  joinedAt       DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@id([organizationId, userId])
  @@index([userId, status, createdAt])
  @@index([organizationId, role, status])
}

model TeacherProfile {
  userId         String        @id
  organizationId String?
  displayName    String?
  title          String?
  bio            String?
  specialties    Json?
  status         String        @default("draft")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id])
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId, status, createdAt])
}

model TeachingGroup {
  id             String                              @id @default(cuid())
  organizationId String?
  ownerId        String
  slug           String                              @unique
  name           String
  code           String?
  externalCode   String?
  groupType      String                              @default("class")
  status         String                              @default("draft")
  summary        String?
  startAt        DateTime?
  endAt          DateTime?
  createdAt      DateTime                            @default(now())
  updatedAt      DateTime                            @updatedAt
  organization   Organization?                       @relation(fields: [organizationId], references: [id])
  owner          User                                @relation("TeachingGroupOwner", fields: [ownerId], references: [id])
  members        TeachingGroupMember[]
  campClasses    CampClass[]
  assignments    TeachingGroupProblemSetAssignment[]

  @@unique([organizationId, externalCode])
  @@index([organizationId, status, createdAt])
  @@index([ownerId, status, createdAt])
}

model TeachingGroupMember {
  groupId    String
  userId     String
  memberRole String        @default("student")
  status     String        @default("active")
  joinedAt   DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  group      TeachingGroup @relation(fields: [groupId], references: [id])
  user       User          @relation(fields: [userId], references: [id])

  @@id([groupId, userId])
  @@index([userId, memberRole, status, createdAt])
  @@index([groupId, memberRole, status])
}

model TeachingGroupProblemSetAssignment {
  id           String                         @id @default(cuid())
  groupId      String
  problemSetId String
  assignedById String
  status       String                         @default("active")
  title        String?
  note         String?
  dueAt        DateTime?
  maxScore     Int                            @default(100)
  gradingMode  String                         @default("auto")
  publishedAt  DateTime?
  createdAt    DateTime                       @default(now())
  updatedAt    DateTime                       @updatedAt
  group        TeachingGroup                  @relation(fields: [groupId], references: [id])
  problemSet   ProblemSet                     @relation(fields: [problemSetId], references: [id])
  assignedBy   User                           @relation("TeachingGroupAssignmentOperator", fields: [assignedById], references: [id])
  grades       TeachingGroupAssignmentGrade[]

  @@unique([groupId, problemSetId])
  @@index([groupId, status, createdAt])
  @@index([problemSetId, status, createdAt])
  @@index([assignedById, createdAt])
}

model TeachingGroupAssignmentGrade {
  id                    String                            @id @default(cuid())
  assignmentId          String
  userId                String
  status                String                            @default("pending")
  autoScore             Int                               @default(0)
  manualScore           Int?
  finalScore            Int                               @default(0)
  maxScore              Int                               @default(100)
  completionRate        Float                             @default(0)
  solvedProblemCount    Int                               @default(0)
  attemptedProblemCount Int                               @default(0)
  submissionCount       Int                               @default(0)
  lastSubmissionAt      DateTime?
  gradedAt              DateTime?
  gradedById            String?
  feedback              String?
  createdAt             DateTime                          @default(now())
  updatedAt             DateTime                          @updatedAt
  assignment            TeachingGroupProblemSetAssignment @relation(fields: [assignmentId], references: [id])
  user                  User                              @relation(fields: [userId], references: [id])
  gradedBy              User?                             @relation("TeachingGroupAssignmentGradeGrader", fields: [gradedById], references: [id])

  @@unique([assignmentId, userId])
  @@index([assignmentId, status, finalScore])
  @@index([userId, updatedAt])
  @@index([gradedById, gradedAt])
}

model OrganizationApiKey {
  id             String       @id @default(cuid())
  organizationId String
  createdById    String
  name           String
  tokenHash      String       @unique
  status         String       @default("active")
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdBy      User         @relation(fields: [createdById], references: [id])

  @@index([organizationId, status, createdAt])
  @@index([createdById, createdAt])
  @@index([expiresAt])
}

model ContentAsset {
  id           String   @id @default(cuid())
  assetType    String
  title        String
  description  String?
  status       String   @default("draft")
  sourceUrl    String
  storageKey   String?
  mimeType     String?
  durationSec  Int?
  thumbnailUrl String?
  resourceType String?
  resourceId   String?
  metadata     Json?
  uploaderId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  uploader     User     @relation("ContentAssetUploader", fields: [uploaderId], references: [id])

  @@index([assetType, status, createdAt])
  @@index([resourceType, resourceId])
  @@index([uploaderId, createdAt])
}

model ContentWorkflowLog {
  id           String   @id @default(cuid())
  resourceType String
  resourceId   String
  fromStatus   String?
  toStatus     String
  action       String
  note         String?
  payload      Json?
  operatorId   String
  createdAt    DateTime @default(now())
  operator     User     @relation("ContentWorkflowOperator", fields: [operatorId], references: [id])

  @@index([resourceType, resourceId, createdAt])
  @@index([operatorId, createdAt])
  @@index([toStatus, createdAt])
}

