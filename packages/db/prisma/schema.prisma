model TestdataGenerationTask {
  id                    String                       @id @default(cuid())
  problemId             String
  problemVersionId      String
  standardSolutionId    String
  requestedById         String
  status                TestdataGenerationTaskStatus @default(PENDING)
  stage                 TestdataGenerationTaskStage  @default(VALIDATE_CONFIG)
  mode                  TestdataPublishMode          @default(APPEND)
  queueName             String                       @default("testgen:jobs")
  workerId              String?
  batchKey              String?
  requestFingerprint    String?
  seed                  String?
  attemptNo             Int                          @default(1)
  retriedFromTaskId     String?
  configSnapshot        Json
  solutionSnapshot      Json
  plannedCaseCount      Int                          @default(0)
  generatedCaseCount    Int                          @default(0)
  succeededCaseCount    Int                          @default(0)
  failedCaseCount       Int                          @default(0)
  persistedCaseCount    Int                          @default(0)
  replacedTestcaseCount Int                          @default(0)
  compileExitCode       Int?
  compileDurationMs     Int?
  compileStdoutAssetId  String?
  compileStderrAssetId  String?
  packageAssetId        String?
  errorCode             String?
  errorMessage          String?                      @db.Text
  resultSummary         Json?
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt
  problem               Problem                      @relation(fields: [problemId], references: [id])
  problemVersion        ProblemVersion               @relation(fields: [problemVersionId], references: [id])
  standardSolution      StandardSolution             @relation(fields: [standardSolutionId], references: [id])
  requestedBy           User                         @relation("TestdataGenerationRequester", fields: [requestedById], references: [id])
  retriedFromTask       TestdataGenerationTask?      @relation("TestdataTaskRetryChain", fields: [retriedFromTaskId], references: [id])
  retries               TestdataGenerationTask[]     @relation("TestdataTaskRetryChain")
  compileStdoutAsset    FileAsset?                   @relation("TestdataTaskCompileStdoutAsset", fields: [compileStdoutAssetId], references: [id])
  compileStderrAsset    FileAsset?                   @relation("TestdataTaskCompileStderrAsset", fields: [compileStderrAssetId], references: [id])
  packageAsset          FileAsset?                   @relation("TestdataTaskPackageAsset", fields: [packageAssetId], references: [id])
  cases                 TestdataCase[]
  logs                  TestdataGenerationLog[]
  publishedTestcases    Testcase[]                   @relation("GeneratedTestcases")

  @@index([problemId, createdAt])
  @@index([problemVersionId, createdAt])
  @@index([standardSolutionId, createdAt])
  @@index([requestedById, createdAt])
  @@index([status, createdAt])
  @@index([stage, createdAt])
  @@index([batchKey, createdAt])
  @@index([retriedFromTaskId])
  @@index([queueName, status, createdAt])
  @@index([requestFingerprint])
}

model TestdataCase {
  id                    String                  @id @default(cuid())
  taskId                String
  ordinal               Int
  groupKey              String?
  title                 String?
  score                 Int                     @default(0)
  isSample              Boolean                 @default(false)
  isPretest             Boolean                 @default(false)
  visible               Boolean                 @default(false)
  caseType              Int                     @default(1)
  subtaskId             Int?
  groupId               String?
  orderIndex            Int?
  caseSeed              String?
  generatorInput        Json?
  inputAssetId          String?
  expectedOutputAssetId String?
  runtimeStderrAssetId  String?
  status                TestdataCaseStatus      @default(PENDING)
  executionStatus       ProgramExecutionStatus  @default(NOT_STARTED)
  executionDurationMs   Int?
  executionMemoryKb     Int?
  exitCode              Int?
  errorCode             String?
  errorMessage          String?                 @db.Text
  metadata              Json?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  task                  TestdataGenerationTask  @relation(fields: [taskId], references: [id])
  inputAsset            FileAsset?              @relation("TestdataCaseInputAsset", fields: [inputAssetId], references: [id])
