  stderrAsset   FileAsset?                  @relation("TestdataLogStderrAsset", fields: [stderrAssetId], references: [id])

  @@unique([taskId, sequenceNo])
  @@index([taskId, createdAt])
  @@index([caseId, createdAt])
  @@index([taskId, level, createdAt])
  @@index([taskId, stage, createdAt])
}

model ProblemSet {
  id               String                              @id @default(cuid())
  slug             String?                             @unique
  title            String
  summary          String?
  description      String?
  kind             String                              @default("training_path")
  status           String                              @default("published")
  visibility       String                              @default("public")
  ownerId          String
  createdAt        DateTime                            @default(now())
  updatedAt        DateTime                            @updatedAt
  owner            User                                @relation(fields: [ownerId], references: [id])
  items            ProblemSetItem[]
  classAssignments TeachingGroupProblemSetAssignment[]

  @@index([kind, status, createdAt])
  @@index([visibility, status, createdAt])
}

model ProblemSetItem {
  setId      String
  problemId  String
  orderIndex Int
  set        ProblemSet @relation(fields: [setId], references: [id])
  problem    Problem    @relation(fields: [problemId], references: [id])

  @@id([setId, problemId])
  @@index([setId, orderIndex])
}

model ProblemStat {
  problemId           String   @id
  totalSubmissions    Int      @default(0)
  acceptedSubmissions Int      @default(0)
  passRate            Float    @default(0)
  avgTimeMs           Int      @default(0)
  avgMemoryMb         Int      @default(0)
  updatedAt           DateTime @default(now())
  problem             Problem  @relation(fields: [problemId], references: [id])
}

model ModerationLog {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  action     String
  reason     String?
  adminId    String
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])

  @@index([targetType, targetId])
  @@index([adminId, createdAt])
}

model AdminProblemBulkOperationLog {
  id            String   @id @default(cuid())
  adminId       String
  action        String
  selectionMode String
  filters       Json?
  payload       Json
  matchedCount  Int      @default(0)
  targets       Json
  result        Json?
  createdAt     DateTime @default(now())
  admin         User     @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

model UserProblemProgress {
  userId           String
  problemId        String
  status           Int       @default(0)
  attempts         Int       @default(0)
  bestScore        Int       @default(0)
  lastStatus       String?
  solvedAt         DateTime?
  lastSubmissionId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id])
  problem          Problem   @relation(fields: [problemId], references: [id])

  @@id([userId, problemId])
  @@index([userId, updatedAt])
  @@index([userId, solvedAt])
  @@index([userId, status, updatedAt])
  @@index([problemId])
}
