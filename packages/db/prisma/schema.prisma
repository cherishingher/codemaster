datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  phone       String?  @unique
  emailVerifiedAt DateTime?
  phoneVerifiedAt DateTime?
  password    String
  name        String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       UserRole[]
  sessions    Session[]
  submissions Submission[]
  enrollments Enrollment[]
  orders      Order[]
  posts       Post[]
  comments    Comment[]
  contestParticipants ContestParticipant[]
  moderationLogs ModerationLog[]
  adminProblemBulkOperationLogs AdminProblemBulkOperationLog[]
  solutions   Solution[]
  problemSets ProblemSet[]
  problemProgress UserProblemProgress[]
  entitlements Entitlement[]
}

model VerificationCode {
  id        String   @id @default(cuid())
  target    String
  type      String
  purpose   String   @default("register")
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  ip        String?
  createdAt DateTime @default(now())

  @@index([target, type, purpose, createdAt])
  @@index([expiresAt])
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  users UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User  @relation(fields: [userId], references: [id])
  role   Role  @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Problem {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  difficulty  Int
  status      Int      @default(0)
  visible     Boolean  @default(true)
  defunct     String   @default("N") @db.Char(1)
  visibility  String   @default("public")
  source      String?
  publishedAt DateTime?
  totalSubmissions Int @default(0)
  acceptedSubmissions Int @default(0)
  passRate    Float    @default(0)
  currentVersionId String? @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tags        ProblemTag[]
  versions    ProblemVersion[] @relation("ProblemVersions")
  currentVersion ProblemVersion? @relation("ProblemCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  submissions Submission[]
  contestProblems ContestProblem[]
  solutions   Solution[]
  problemSetItems ProblemSetItem[]
  stats       ProblemStat?
  progress    UserProblemProgress[]
  hustojMap   HustojProblemMap?

  @@index([difficulty])
  @@index([status, visible, defunct, publishedAt])
  @@index([createdAt])
}

model ProblemVersion {
  id            String @id @default(cuid())
  problemId     String
  version       Int
  statement     String
  statementMd   String?
  constraints   String?
  hints         String?
  inputFormat   String?
  outputFormat  String?
  samples       Json?
  scratchRules  Json?
  notes         String?
  timeLimitMs   Int
  memoryLimitMb Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  problem       Problem @relation("ProblemVersions", fields: [problemId], references: [id])
  currentFor    Problem[] @relation("ProblemCurrentVersion")
  testcases     Testcase[]
  judgeConfigs  ProblemJudgeConfig[]
  submissions   Submission[]
  solutions     Solution[]

  @@unique([problemId, version])
  @@index([problemId])
  @@index([problemId, createdAt])
}

model Testcase {
  id        String @id @default(cuid())
  versionId String
  title     String?
  caseType  Int    @default(1)
  visible   Boolean @default(false)
  inputUri  String
  outputUri String
  score     Int
  timeLimitMs Int?
  memoryLimitKb Int?
  subtaskId Int?
  isPretest Boolean @default(false)
  groupId   String?
  isSample  Boolean @default(false)
  orderIndex Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   ProblemVersion @relation(fields: [versionId], references: [id])
  cases     SubmissionCase[]

  @@index([versionId])
  @@index([versionId, caseType, orderIndex])
  @@index([versionId, groupId])
}

model Tag {
  id       String @id @default(cuid())
  name     String @unique
  problems ProblemTag[]
}

model ProblemTag {
  problemId String
  tagId     String
  problem   Problem @relation(fields: [problemId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([problemId, tagId])
  @@index([tagId])
}

model Submission {
  id        String   @id @default(cuid())
  userId    String
  problemId String
  problemVersionId String
  lang      String
  languageId Int?
  codeUri   String?
  code      String?  @db.Text
  status    String   @default("QUEUED")
  judgeResult Int    @default(0)
  score     Int      @default(0)
  judgeBackend String @default("hustoj")
  hustojSolutionId Int?
  timeUsedMs Int?
  memoryUsedKb Int?
  visible   Boolean  @default(true)
  defunct   String   @default("N") @db.Char(1)
  createdAt DateTime @default(now())
  finishedAt DateTime?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  problem   Problem  @relation(fields: [problemId], references: [id])
  problemVersion ProblemVersion @relation(fields: [problemVersionId], references: [id])
  cases     SubmissionCase[]
  sourceCode SourceCode?
  compileInfo CompileInfo?
  runtimeInfo RuntimeInfo?

  @@index([userId, createdAt])
  @@index([problemId, createdAt])
  @@index([status])
  @@index([judgeResult, createdAt])
  @@index([problemVersionId, createdAt])
}

model HustojProblemMap {
  id              String   @id @default(cuid())
  problemId       String   @unique
  hustojProblemId Int      @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  problem         Problem  @relation(fields: [problemId], references: [id])

  @@index([hustojProblemId])
}

model SubmissionCase {
  id           String @id @default(cuid())
  submissionId String
  testcaseId   String?
  ordinal      Int?
  status       String
  judgeResult  Int    @default(0)
  timeMs       Int
  memoryMb     Int
  score        Int
  inputPreview String? @db.Text
  outputPreview String? @db.Text
  expectedPreview String? @db.Text
  checkerMessage String? @db.Text
  createdAt    DateTime @default(now())
  submission   Submission @relation(fields: [submissionId], references: [id])
  testcase     Testcase? @relation(fields: [testcaseId], references: [id])

  @@index([submissionId])
  @@index([submissionId, ordinal])
  @@unique([submissionId, testcaseId])
}

model ProblemJudgeConfig {
  id             String   @id @default(cuid())
  versionId      String
  language       String
  languageId     Int
  judgeMode      String   @default("standard")
  timeLimitMs    Int?
  memoryLimitMb  Int?
  templateCode   String?  @db.Text
  templateCodeUri String?
  entrypoint     String?
  entrySignature String?
  compileCommand String?
  runCommand     String?
  isEnabled      Boolean  @default(true)
  isDefault      Boolean  @default(false)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  version        ProblemVersion @relation(fields: [versionId], references: [id])

  @@unique([versionId, language])
  @@index([versionId, isEnabled, sortOrder])
  @@index([languageId])
}

model SourceCode {
  submissionId String   @id
  source       String?  @db.Text
  objectKey    String?
  storageType  String   @default("inline")
  sourceSize   Int?
  sourceHash   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id])
}

model CompileInfo {
  submissionId String   @id
  compiler     String?
  command      String?
  exitCode     Int?
  message      String?  @db.Text
  objectKey    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  submission   Submission @relation(fields: [submissionId], references: [id])
}

model RuntimeInfo {
  submissionId   String   @id
  exitCode       Int?
  signal         String?
  stdoutPreview  String?  @db.Text
  stderrPreview  String?  @db.Text
  checkerMessage String?  @db.Text
  objectKey      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  submission     Submission @relation(fields: [submissionId], references: [id])
}

model Contest {
  id           String @id @default(cuid())
  name         String
  startAt      DateTime
  endAt        DateTime
  rule         String @default("ACM")
  problems     ContestProblem[]
  participants ContestParticipant[]

  @@index([startAt, endAt])
}

model ContestProblem {
  contestId String
  problemId String
  order     Int
  contest   Contest @relation(fields: [contestId], references: [id])
  problem   Problem @relation(fields: [problemId], references: [id])

  @@id([contestId, problemId])
  @@index([contestId, order])
}

model ContestParticipant {
  contestId String
  userId    String
  status    String @default("joined")
  contest   Contest @relation(fields: [contestId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@id([contestId, userId])
  @@index([contestId])
}

model Course {
  id          String @id @default(cuid())
  slug        String @unique
  title       String
  summary     String?
  description String?
  category    String?
  coverImage  String?
  status      String @default("draft")
  sortOrder   Int    @default(0)
  sections    Section[]
  enrollments Enrollment[]

  @@index([status, sortOrder])
  @@index([category, sortOrder])
}

model Section {
  id          String @id @default(cuid())
  slug        String @unique
  courseId    String
  title       String
  description String?
  sortOrder   Int    @default(0)
  lessons     Lesson[]
  course      Course @relation(fields: [courseId], references: [id])

  @@index([courseId, sortOrder])
}

model Lesson {
  id           String @id @default(cuid())
  slug         String @unique
  sectionId    String
  title        String
  type         String
  summary      String?
  content      String?
  thumbnailUrl String?
  assetUri     String?
  durationSec  Int?
  isPreview    Boolean @default(false)
  sortOrder    Int     @default(0)
  section      Section @relation(fields: [sectionId], references: [id])

  @@index([sectionId, sortOrder])
}

model Enrollment {
  id       String @id @default(cuid())
  userId   String
  courseId String
  status   String @default("active")
  user     User   @relation(fields: [userId], references: [id])
  course   Course @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([courseId])
}

model Product {
  id           String @id @default(cuid())
  name         String
  priceCents   Int
  type         String
  validDays    Int?
  orders       Order[]
  entitlements Entitlement[]

  @@index([type])
}

model Order {
  id          String @id @default(cuid())
  userId      String
  productId   String?
  amountCents Int
  status      String @default("created")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])
  payments    Payment[]

  @@index([userId, createdAt])
  @@index([productId, createdAt])
}

model Payment {
  id      String @id @default(cuid())
  orderId String
  channel String
  status  String
  paidAt  DateTime?
  order   Order    @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Entitlement {
  id        String   @id @default(cuid())
  userId    String
  productId String
  grantedAt DateTime @default(now())
  expiresAt DateTime?
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([userId, expiresAt])
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  comments  Comment[]

  @@index([status, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  status    String   @default("pending")
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([postId, createdAt])
}

model Solution {
  id         String   @id @default(cuid())
  problemId  String
  versionId  String?
  type       String   @default("official") // official/ugc
  title      String
  content    String
  videoUrl   String?
  authorId   String
  visibility String   @default("public")
  createdAt  DateTime @default(now())
  problem    Problem  @relation(fields: [problemId], references: [id])
  author     User     @relation(fields: [authorId], references: [id])
  version    ProblemVersion? @relation(fields: [versionId], references: [id])

  @@index([problemId, createdAt])
  @@index([authorId, createdAt])
}

model ProblemSet {
  id          String   @id @default(cuid())
  title       String
  description String?
  visibility  String   @default("public")
  ownerId     String
  createdAt   DateTime @default(now())
  owner       User     @relation(fields: [ownerId], references: [id])
  items       ProblemSetItem[]
}

model ProblemSetItem {
  setId     String
  problemId String
  orderIndex Int
  set       ProblemSet @relation(fields: [setId], references: [id])
  problem   Problem    @relation(fields: [problemId], references: [id])

  @@id([setId, problemId])
  @@index([setId, orderIndex])
}

model ProblemStat {
  problemId          String  @id
  totalSubmissions   Int     @default(0)
  acceptedSubmissions Int    @default(0)
  passRate           Float   @default(0)
  avgTimeMs          Int     @default(0)
  avgMemoryMb        Int     @default(0)
  updatedAt          DateTime @default(now())
  problem            Problem @relation(fields: [problemId], references: [id])
}

model ModerationLog {
  id         String   @id @default(cuid())
  targetType String
  targetId   String
  action     String
  reason     String?
  adminId    String
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])

  @@index([targetType, targetId])
  @@index([adminId, createdAt])
}

model AdminProblemBulkOperationLog {
  id            String   @id @default(cuid())
  adminId       String
  action        String
  selectionMode String
  filters       Json?
  payload       Json
  matchedCount  Int      @default(0)
  targets       Json
  result        Json?
  createdAt     DateTime @default(now())
  admin         User     @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

model UserProblemProgress {
  userId          String
  problemId       String
  status          Int      @default(0)
  attempts        Int      @default(0)
  bestScore       Int      @default(0)
  lastStatus      String?
  solvedAt        DateTime?
  lastSubmissionId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
  problem         Problem  @relation(fields: [problemId], references: [id])

  @@id([userId, problemId])
  @@index([userId, updatedAt])
  @@index([userId, status, updatedAt])
  @@index([problemId])
}
